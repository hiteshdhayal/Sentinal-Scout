# Your Solana wallet address (base58, 32-44 chars)
WALLET_ADDRESS=YOUR_WALLET_ADDRESS_HERE

# Your Solana wallet private key (base58, required for executing trades/migrations)
WALLET_PRIVATE_KEY=YOUR_BASE58_PRIVATE_KEY_HERE

# Solana RPC URL (mainnet or devnet)
SOLANA_RPC=https://api.devnet.solana.com

# Anthropic API key — get it at https://console.anthropic.com
# Must start with sk-ant-
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# Zerion API key — get it at https://developers.zerion.io
ZERION_API_KEY=YOUR_ZERION_API_KEY_HERE

# LPAgent API key — get it at https://lpagent.io
LPAGENT_API_KEY=YOUR_LPAGENT_API_KEY_HERE

# Telegram bot token — create a bot at https://t.me/BotFather
# Format: 123456789:AAFxxxxxxxx
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Telegram chat ID — get it by messaging @userinfobot
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# X (Twitter) credentials — create an app at https://developer.twitter.com
X_API_KEY=YOUR_X_API_KEY_HERE
X_API_SECRET=YOUR_X_API_SECRET_HERE
X_ACCESS_TOKEN=YOUR_X_ACCESS_TOKEN_HERE
X_ACCESS_SECRET=YOUR_X_ACCESS_SECRET_HERE

# Supabase project URL — get it at https://supabase.com → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key — same settings page
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# Risk score threshold (0-100). Agent hedges when score exceeds this value.
# 50 = conservative, 70 = balanced (default), 85 = aggressive
RISK_THRESHOLD=70

# Minimum APY improvement percentage to trigger LP migration
# 10 = frequent, 20 = balanced (default), 30 = only big moves
YIELD_IMPROVEMENT_PCT=20

# Agent mode: "autonomous" executes trades, "notify" sends alerts only
AGENT_MODE=autonomous

# How often to run the risk scan (minutes). Default: 15
RISK_INTERVAL_MIN=15

# How often to run the yield scan (minutes). Default: 60
YIELD_INTERVAL_MIN=60
